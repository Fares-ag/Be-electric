# Supabase (required)
# Get from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Required for: (1) "Add User" (admin creates users), (2) push notifications when assigning work orders / PM tasks
# Get from Supabase Dashboard → Project Settings → API → service_role (secret)
# In production (Vercel): add this in Project → Settings → Environment Variables so push works.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
